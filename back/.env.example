# ─── Base de datos (PostgreSQL — igual que u_05_v2) ──────────────────────────
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=
POSTGRES_HOST=
POSTGRES_PORT=

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generar con: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=
ALGORITHM=
ACCESS_TOKEN_EXPIRE_MINUTES=

# ─── Cloudinary ────────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=


# ─── MP ─────────────────────────────────────────────────────────────
# Se obtienen del dashboard de desarrollador de MercadoPago.
# Usar credenciales de prueba (TEST), NUNCA las de producción.
MP_ACCESS_TOKEN=TEST-tu-access-token-de-mercadopago
MP_PUBLIC_KEY=TEST-tu-public-key-de-mercadopago

# URL del webhook (externa, ej: ngrok).
# Solo si se quiere probar webhook IPN desde MP.
MP_WEBHOOK_URL=https://tu-subdominio.ngrok-free.app/api/v1/pagos/webhook

# URL pública de ngrok para back_urls HTTPS en la preferencia de MP.
# Necesaria porque MercadoPago exige HTTPS en back_urls en producción.
NGROK_URL=https://tu-subdominio.ngrok-free.app
FRONTEND_CLIENTE_URL=http://localhost:5174